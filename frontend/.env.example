# Vercel → Project Settings → Environment Variables → Production
#
# Zorunlu (admin paneli ve zimmet için):
# MONGO_URL=mongodb+srv://kullanici:sifre@cluster.mongodb.net/it_helpdesk?retryWrites=true&w=majority
# DB_NAME=it_helpdesk
# SECRET_KEY=en-az-32-karakter-uzunlugunda-guclu-rastgele-metin
#
# İlk kurulumda (veritabanında admin yokken) bir kez kullanılır, sonra kaldırılabilir:
# BOOTSTRAP_ADMIN_USER=admin
# BOOTSTRAP_ADMIN_PASSWORD=guclu-bir-sifre-en-az-10-karakter
#
# Opsiyonel — harici backend kullanacaksanız (varsayılan: aynı Vercel sitesindeki /api):
# REACT_APP_API_URL=
#
# Opsiyonel — Yurtiçi Kargo canlı takip (Vercel Production ortam değişkenleri):
# YURTICI_KARGO_USER=web-servis-kullanici-adi
# YURTICI_KARGO_PASSWORD=web-servis-sifresi
# YURTICI_KARGO_CUSTOMER_CODE=331862405
# YURTICI_KARGO_LANGUAGE=TR
# YURTICI_KARGO_TEST_MODE=false
